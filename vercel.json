{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "CI=false REACT_APP_SENTRY_RELEASE=$VERCEL_GIT_COMMIT_SHA npm run build",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "git": {
    "deploymentEnabled": {
      "dev": false,
      "production-disabled": false
    }
  }
}
