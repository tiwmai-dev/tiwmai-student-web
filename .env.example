# Student Frontend Environment Variables

# API Configuration
# Backend API URL (update this to match your backend server)
REACT_APP_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Optional PostHog project key. Leave blank to disable analytics locally.
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
REACT_APP_ENVIRONMENT=local

# Optional Sentry error monitoring. Leave blank to disable locally.
# Create two Sentry projects (recommended slugs):
#   - student-web-staging
#   - student-web-production
# Org slug: tp-aitech-co-ltd
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENVIRONMENT=local
REACT_APP_SENTRY_SEND_DEFAULT_PII=true
# Injected automatically on Vercel builds (see vercel.json buildCommand).
REACT_APP_SENTRY_RELEASE=

# Build-time only (set in Vercel, never commit real values):
# SENTRY_ORG=tp-aitech-co-ltd
# SENTRY_PROJECT=student-web-staging   # Preview deployments
# SENTRY_PROJECT=student-web-production # Production deployments
# SENTRY_AUTH_TOKEN=sntrys_...

# For WSL2 users on Windows, you may need to use the WSL2 IP address
# To find your WSL2 IP: run `hostname -I` in WSL2
# Example: REACT_APP_API_BASE_URL=http://172.19.220.248:8000/api/v1

# For Docker deployments
# REACT_APP_API_BASE_URL=http://backend:8000/api/v1

# For Vercel production deployments
# REACT_APP_API_BASE_URL=https://your-tiwmai-api.vercel.app/api/v1
